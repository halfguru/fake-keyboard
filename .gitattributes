# Auto detect text files and perform LF normalization
* text=auto

# C++ source files
*.cpp text eol=lf
*.hpp text eol=lf
*.h text eol=lf
*.c text eol=lf

# Build files
CMakeLists.txt text eol=lf
*.cmake text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Python
*.py text eol=lf

# Shell scripts
*.sh text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Config files
.clang-format text eol=lf
.clang-tidy text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
